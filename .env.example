# ===== www2video — Environment Variables =====

# Required: Google Gemini API Key (for composition generation)
# Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Required: Google Cloud Service Account JSON path (for TTS via Vertex AI)
# Point to your service account JSON key file
TTS_SERVICE_ACCOUNT_PATH=/app/keys/service-account.json

# Required: Google Cloud Project ID (for Vertex AI TTS)
GCLOUD_PROJECT=gen-lang-client-0575393893

# Optional: Pexels API Key (for stock video search)
# Get yours at https://www.pexels.com/api/
# When set, the "useStockVideo" option will search and embed stock footage
PEXELS_API_KEY=

# Server port (default: 3017)
PORT=3017

# Node environment: development | production
NODE_ENV=production

# Chrome headless shell path (for website scraping)
# Docker: /usr/local/bin/chrome-headless-shell
# Local: /usr/bin/google-chrome-stable or /usr/bin/chromium
CHROME_HEADLESS_SHELL_PATH=/usr/local/bin/chrome-headless-shell

# Database file path (sql.js)
DB_PATH=/app/server/data/www2video.db

# Project files directory (composition workspaces)
PROJECTS_DIR=/app/server/data/projects

# Render output directory (MP4 files)
RENDERS_DIR=/app/server/renders

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
